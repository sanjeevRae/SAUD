/saud-leather/products/kil31gwhkkgsvrpbdqu2.jpg","reviewCount":5,"category":"Leather Bags","colors":[],"seoKeywords":[],"sizes":["One Size"],"name":"File bag ","price":8500,"seoTitle":"File bag  | Saud Leather","seoDescription":"","canonicalPath":"/product/18","linkHref":"/product/18"},{"id":"19","ogImage":"https://res.cloudinary.com/blgfwhoo/image/upload/v1783279237/saud-leather/products/q3r2uegglopqmaitqrzz.jpg","reviewCount":4,"category":"Leather Bags","colors":[],"seoKeywords":[],"description":"","rating":5,"name":"Corco laptop bag","price":10000,"sizes":["One Size"],"images":["https://res.cloudinary.com/blgfwhoo/image/upload/v1783279237/saud-leather/products/q3r2uegglopqmaitqrzz.jpg","https://res.cloudinary.com/blgfwhoo/image/upload/v1783279245/saud-leather/products/olrlx8frbvkr7xzo0csj.jpg"],"stock":13,"image":"https://res.cloudinary.com/blgfwhoo/image/upload/v1783279237/saud-leather/products/q3r2uegglopqmaitqrzz.jpg","seoTitle":"Corco laptop bag | Saud Leather","seoDescription":"","canonicalPath":"/product/19","linkHref":"/product/19"}],"collections":[{"id":"1","title":"Half rider jacket","productId":"7","image":"https://res.cloudinary.com/blgfwhoo/image/upload/v1783268392/saud-leather/collections/h4rsrclqfyo6h09xgv8s.jpg","enabled":true},{"id":"2","image":"https://res.cloudinary.com/blgfwhoo/image/upload/v1783273179/saud-leather/collections/w57dqdaj4s5vtxpjobou.jpg","title":"White wash jacket ","productId":"4","enabled":true},{"id":"3","enabled":true,"productId":"4","title":"Rider jacket","price":0,"images":[],"rating":5,"stock":0,"featuredOrder":2,"image":"https://res.cloudinary.com/blgfwhoo/image/upload/v1783273319/saud-leather/collections/mtr7xqvujxsjyxsijzw8.jpg"},{"id":"4","enabled":true,"title":"Bumper jacket","productId":"4","image":"https://res.cloudinary.com/blgfwhoo/image/upload/v1783273794/saud-leather/collections/rodmldjgs7vur5dzhgtd.jpg"},{"id":"5","image":"https://res.cloudinary.com/blgfwhoo/image/upload/v1783274066/saud-leather/collections/brdylz2yxr1h2am1filw.jpg","title":"Half jeans jacket","productId":"11","enabled":true},{"id":"6","enabled":true,"image":"https://res.cloudinary.com/blgfwhoo/image/upload/v1783280053/saud-leather/collections/e428uutjxw8quq2imejk.jpg","productId":"22","title":"Rider jacket"}],"categories":[{"id":"1","stock":100,"image":"https://res.cloudinary.com/blgfwhoo/image/upload/v1783275183/saud-leather/categories/khbrrl3qzxazo1ipifd8.jpg","enabled":true,"name":"Leather Bags"},{"id":"2","stock":50,"name":"Leather Jackets","enabled":true,"image":"https://res.cloudinary.com/blgfwhoo/image/upload/v1783275277/saud-leather/categories/wxvnkipamx5jhbsx1uex.jpg"}],"testimonials":[{"id":"1","date":"2 days ago","rating":4.9,"avatar":"https://res.cloudinary.com/dngbvnleh/image/upload/v1781428964/chitratech-shop/testimonials/f0yk5tr9i0tnhmefk3b5.jpg","text":"The fit feels very flattering and the pieces are easy to mix and match with other items in my wardrobe. Quality that truly lasts.","name":"Mina Gurung"},{"id":"2","text":"The fit feels considered, like it was tailored without the tailor. Minimal branding, maximum quality. Exactly what I wanted.","rating":4.9,"date":"1 week ago","avatar":"https://res.cloudinary.com/dngbvnleh/image/upload/v1781434299/chitratech-shop/testimonials/wnf8dukaoaakznlohnyu.webp","name":"Jenish Shrestha"},{"id":"3","name":"Messi","rating":4.9,"avatar":"https://res.cloudinary.com/dngbvnleh/image/upload/v1781429135/chitratech-shop/testimonials/efvsr9bsppyxzzoukno6.jpg","date":"2 weeks ago","text":"I now own three pairs of the trousers. That says everything. The fabric comfort is unmatched in this price range."},{"id":"4","text":"The fit feels very flattering and the pieces are easy to mix and match with other items in my wardrobe.","avatar":"https://res.cloudinary.com/dngbvnleh/image/upload/v1781429116/chitratech-shop/testimonials/wvsd3nil2f0ns1ap3lbi.jpg","date":"3 weeks ago","rating":4.9,"name":"Karina"},{"id":"5","text":"The jacket feels modern without being overdone. I can wear it for a smart look during the week and still style it casually on weekends.","avatar":"https://res.cloudinary.com/dngbvnleh/image/upload/v1781428919/chitratech-shop/testimonials/hor7f8etiqunk3gc1q8l.jpg","rating":4.8,"date":"1 month ago","name":"Bhuwan"},{"id":"6","name":"Wonyoung ","rating":4.9,"date":"1 month ago","avatar":"https://preview.redd.it/240109-jang-wonyoung-instagram-update-v0-1by307c1xdbc1.jpg?width=1080&crop=smart&auto=webp&s=ee8860eec92f5f578f5b21baad1974370e8dbf9a","text":"Every piece feels intentional. The fabric, color, and fit make simple outfits look much more polished."}],"socialLinks":[{"id":"tiktok","enabled":true,"href":"https://www.tiktok.com/@saud.leather.craf","platform":"TikTok"}]}}]
