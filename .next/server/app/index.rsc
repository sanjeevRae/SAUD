5:["$","$L11",null,{"homepage":{"noticeBanners":[{"id":"main-notice","ctaLabel":"Shop now","enabled":true,"countdownTo":"2026-07-06T18:03:31.277Z","message":"Get up to 10% Off This Summer Sale. Grab It Fast!","title":"Summer Sale","ctaHref":"/main-product"}],"heroBanners":[{"id":"hero-main","description":"Discover refined everyday pieces, seasonal staples, and fashion-forward essentials.","primaryHref":"/main-product","enabled":true,"secondaryLabel":"Learn More","image":"https://res.cloudinary.com/dngbvnleh/image/upload/v1782768672/saud-leather/hero/fptk4tqckcmdxtn0zs6g.png","primaryLabel":"Shop Now","title":"Unleash Your Best Look with Saud Leather Signatures","eyebrow":"New Season","secondaryHref":"#collection"}],"featuredProducts":[{"id":"3","price":17000,"featuredOrder":2,"sizes":["S","M","L","XL","XXL","XXXL"],"image":"https://res.cloudinary.com/blgfwhoo/image/upload/v1783280324/saud-leather/featured/lqdzg4d9qmsvhkstbvys.jpg","name":"Rider jacket","images":["https://res.cloudinary.com/blgfwhoo/image/upload/v1783280324/saud-leather/featured/lqdzg4d9qmsvhkstbvys.jpg","https://res.cloudinary.com/blgfwhoo/image/upload/v1783280313/saud-leather/featured/hil6jj0bkzagb1erwtc0.jpg","https://res.cloudinary.com/blgfwhoo/image/upload/v1783280307/saud-leather/featured/tzslbowzecsghyuzf3qh.jpg","https://res.cloudinary.com/blgfwhoo/image/upload/v1783280298/saud-leather/featured/prdb9ocqnlszyq3rlfdl.jpg"],"stock":9,"category":"Leather Jacket","rating":5,"enabled":true,"description":"Elevate your style with the Saud Leather Craft rider jacket. Handcrafted from premium locally sourced leather, this timeless piece features a sleek asymmetrical zipper, durable protective padding, and breathable lining. Perfect for city riding or a bold casual look, it seamlessly blends rugged durability with refined elegance.","seoTitle":"Rider jacket | Saud Leather","seoDescription":"Elevate your style with the Saud Leather Craft rider jacket. Handcrafted from premium locally sourced leather, thi