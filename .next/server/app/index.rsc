/2"},{"id":"1","price":1900,"image":"https://res.cloudinary.com/dngbvnleh/image/upload/v1783099230/saud-leather/featured/jxka0kqgvgrvhrc9uqwk.png","name":"pokemon","images":["https://res.cloudinary.com/dngbvnleh/image/upload/v1783099230/saud-leather/featured/jxka0kqgvgrvhrc9uqwk.png","https://res.cloudinary.com/dngbvnleh/image/upload/v1783099252/saud-leather/featured/puoe3fjk8ktvpqnzbldw.jpg","https://res.cloudinary.com/dngbvnleh/image/upload/v1783099236/saud-leather/featured/qbn1aeftcoh8yxrf6pkw.png","https://res.cloudinary.com/dngbvnleh/image/upload/v1783099220/saud-leather/featured/vuyptyyas4qy6a0dkzio.png"],"category":"pokemon","enabled":true,"sizes":["S","M","L","XS","XL"],"seoTitle":"pokemon | Saud Leather","seoDescription":"$undefined","ogImage":"https://res.cloudinary.com/dngbvnleh/image/upload/v1783099230/saud-leather/featured/jxka0kqgvgrvhrc9uqwk.png","canonicalPath":"/product/1","linkHref":"/product/1"}],"latestProducts":[{"id":"4","image":"$11","price":500,"seoKeywords":["Leather Wallet"],"seoTitle":"Leather Wallet","name":"Leather Wallet","description":"Sophisticated pleated dress with waist belt. Fluid silhouette that moves beautifully.","rating":4.6,"stock":31,"colors":[{"hex":"#7A7A7A","name":"Grey"},{"name":"Black","hex":"#1A1A1A"}],"category":"Dresses","seoDescription":"Sophisticated pleated dress with waist belt. Fluid silhouette that moves beautifully.","canonicalPath":"/product/4","ogImage":"https://res.cloudinary.com/dngbvnleh/image/upload/v1781087833/chitratech-shop/seed/product_04.jpg","sizes":["XS","S","M","L","XL"],"reviewCount":64,"images":["$12"],"linkHref":"/product/4"},{"id":"5","price":1249,"tag":"Best Seller","image":"$13","description":"Loose-fit sweatshirt hoodie in medium weight cotton-blend fabric. Jersey-lined with drawstring hood and kangaroo pocket.","name":"Brown Leather Wallet","seoKeywords":["Leather Wallet"],"seoTitle":"Leather Wallet","colors":[{"name":"Burgundy","hex":"#722F37"},{"name":"Black","hex":"#1A1A1A"},{"name":"Grey","hex":"#808080"}],"rating":4.7,"stock":67,"images":["$14"],"reviewCount":342,"ogImage":"https://res.cloudinary.com/dngbvnleh/image/upload/v1781087832/chitratech-shop/seed/product_05.jpg","sizes":["S","M","L","XL","XXL"],"canonicalPath":"/product/5","category":"Knitwear","seoDescription":"Loose-fit sweatshirt hoodie in medium weight cotton-blend fabric. Jersey-lined with drawstring hood and kangaroo pocket.","linkHref":"/product/5"},{"id":"6","price":132,"image":"https://res.cloudinary.com/dngbvnleh/image/upload/v1781087832/chitratech-shop/seed/product_06.jpg","name":"Canvas Day Bag (Brown)","seoKeywords":["Accessories","ChitraTech Shop","fashion"],"seoTitle":"Canvas Day Bag (Brown) | ChitraTech Shop","description":"Premium leather duffle bag crafted from high-quality materials. Durable and built for everyday use.","colors":[{"name":"Brown","hex":"#8B6914"},{"hex":"#1A1A1A","name":"Black"}],"stock":18,"rating":4.9,"canonicalPath":"/product/6","sizes":["One Size"],"ogImage":"https://res.cloudinary.com/dngbvnleh/image/upload/v1781087832/chitratech-shop/seed/product_06.jpg","seoDescription":"Premium leather duffle bag crafted from high-quality materials. Durable and built for everyday use.","category":"Accessories","images":["https://res.cloudinary.com/dngbvnleh/image/upload/v1781087832/chitratech-shop/seed/product_06.jpg"],"reviewCount":156,"linkHref":"/product/6"}],"collections":[{"id":"1","linkHref":"/main-product?collection=urban-minimalist","image":"https://res.cloudinary.com/dngbvnleh/image/upload/v1781087832/chitratech-shop/seed/collection_01.jpg","title":"Urban Minimalist"},{"id":"2","linkHref":"/main-product?collection=evening-noir","title":"Evening Noir","image":"https://res.cloudinary.com/dngbvnleh/image/upload/v1781087832/chitratech-shop/seed/collection_02.jpg"},{"id":"3","title":"Golden Hour","image":"https://res.cloudinary.com/dngbvnleh/image/upload/v1781103131/chitratech-shop/seed/collection_03.jpg","linkHref":"/main-product?collection=golden-hour"},{"id":"4","image":"https://res.cloudinary.com/dngbvnleh/image/upload/v1781103133/chitratech-shop/seed/collection_04.jpg","title":"Casual Essence","linkHref":"/main-product?collection=casual-essence"},{"id":"5","linkHref":"/main-product?collection=modern-classic","title":"Modern Classic","image":"https://res.cloudinary.com/dngbvnleh/image/upload/v1781087832/chitratech-shop/seed/collection_05.jpg"}],"categories":[{"id":"cami","stock":14,"linkHref":"/main-product?category=Cami","name":"Cami","image":"https://res.cloudinary.com/dngbvnleh/image/upload/v1781103136/chitratech-shop/seed/category_cami.jpg","order":3},{"id":"knitwear","name":"Knitwear","order":2,"image":"https://res.cloudinary.com/dngbvnleh/image/upload/v1781103135/chitratech-shop/seed/category_knitwear.jpg","stock":72,"linkHref":"/main-product?category=Knitwear"},{"id":"polo","stock":52,"linkHref":"/main-product?category=Polo","name":"Polo","image":"https://res.cloudinary.com/dngbvnleh/image/upload/v1781103138/chitratech-shop/seed/category_polo.jpg","order":4},{"id":"t-shirt","order":1,"image":"https://res.cloudinary.com/dngbvnleh/image/upload/v1781103134/chitratech-shop/seed/category_tshirt.jpg","name":"T-Shirt","linkHref":"/main-product?category=T-Shirt","stock":120}],"testimonials":[{"id":"1","text":"The fit feels very flattering and the pieces are easy to mix and match with other items in my wardrobe. Quality that truly lasts.","name":"Mina Gurung","avatar":"https://res.cloudinary.com/dngbvnleh/image/upload/v1781428964/chitratech-shop/testimonials/f0yk5tr9i0tnhmefk3b5.jpg","rating":4.9,"date":"2 days ago"},{"id":"2","avatar":"https://res.cloudinary.com/dngbvnleh/image/upload/v1781434299/chitratech-shop/testimonials/wnf8dukaoaakznlohnyu.webp","date":"1 week ago","rating":4.9,"text":"The fit feels considered, like it was tailored without the tailor. Minimal branding, maximum quality. Exactly what I wanted.","name":"Jenish Shrestha"},{"id":"3","text":"I now own three pairs of the trousers. That says everything. The fabric comfort is unmatched in this price range.","name":"Messi","avatar":"https://res.cloudinary.com/dngbvnleh/image/upload/v1781429135/chitratech-shop/testimonials/efvsr9bsppyxzzoukno6.jpg","date":"2 weeks ago","rating":4.9},{"id":"4","text":"The fit feels very flattering and the pieces are easy to mix and match with other items in my wardrobe.","name":"Karina","avatar":"https://res.cloudinary.com/dngbvnleh/image/upload/v1781429116/chitratech-shop/testimonials/wvsd3nil2f0ns1ap3lbi.jpg","rating":4.9,"date":"3 weeks ago"},{"id":"5","name":"Bhuwan","text":"The jacket feels modern without being overdone. I can wear it for a smart look during the week and still style it casually on weekends.","date":"1 month ago","rating":4.8,"avatar":"https://res.cloudinary.com/dngbvnleh/image/upload/v1781428919/chitratech-shop/testimonials/hor7f8etiqunk3gc1q8l.jpg"},{"id":"6","rating":4.9,"date":"1 month ago","avatar":"https://preview.redd.it/240109-jang-wonyoung-instagram-update-v0-1by307c1xdbc1.jpg?width=1080&crop=smart&auto=webp&s=ee8860eec92f5f578f5b21baad1974370e8dbf9a","name":"Wonyoung ","text":"Every piece feels intentional. The fabric, color, and fit make simple outfits look much more polished."}],"socialLinks":[{"id":"tiktok","platform":"TikTok","enabled":true,"href":"https://www.tiktok.com/@saud.leather.craf"}]}}]
